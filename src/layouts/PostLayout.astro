---
import Layout from "./Layout.astro";
import config from "@/config";
import {
  getBlogPostingStructuredData,
  getBreadcrumbStructuredData,
  serializeJsonLd,
} from "@/utils/structuredData";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  author?: string;
  tags?: string[];
};

const { site } = config;

const {
  title,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  author,
  tags,
} = Astro.props;

const resolvedCanonicalURL =
  canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
const layoutTitle = title ? `${title} | ${site.title}` : site.title;

const structuredData = getBlogPostingStructuredData(config, {
  title,
  description,
  canonicalURL: resolvedCanonicalURL,
  ogImage,
  pubDatetime,
  modDatetime,
  author,
  tags,
});
const breadcrumbStructuredData = getBreadcrumbStructuredData([
  { name: site.title, url: "/" },
  { name: "Posts", url: "/posts/" },
  { name: title ?? site.title, url: resolvedCanonicalURL },
]);
---

<Layout
  title={layoutTitle}
  {description}
  {ogImage}
  canonicalURL={resolvedCanonicalURL}
>
  <Fragment slot="head">
    <!-- Override og:type for article pages -->
    <meta property="og:type" content="article" />

    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <script
      type="application/ld+json"
      is:inline
      set:html={serializeJsonLd(structuredData)}
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={serializeJsonLd(breadcrumbStructuredData)}
    />
  </Fragment>

  <slot />
</Layout>
